# =============================================================================
# Taskpilot Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# --- Authentication & Identity ---
ZUULTIMATE_BASE_URL=http://localhost:8000  # Zuultimate identity server URL

# --- Licensing (Vinzy) ---
VINZY_LICENSE_KEY=  # Your Vinzy license key (leave empty for community edition)
VINZY_SERVER=http://localhost:8080  # Vinzy license server URL

# --- CORS ---
CORS_ORIGINS=http://localhost:3000  # Comma-separated list of allowed origins
